{
  "name": "browser-memory",
  "version": "1.1.0",
  "description": "Chrome Tab Memory Monitor extension build tooling",
  "main": "background.js",
  "scripts": {
    "build": "node build.js",
    "package": "node build.js --zip",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "check": "node -e \"JSON.parse(require('fs').readFileSync('manifest.json','utf8')); console.log('manifest ok')\""
  },
  "keywords": ["webextension", "chrome", "memory", "tabs"],
  "author": "Allen John",
  "license": "MIT",
  "type": "commonjs"
}
